rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPart(partnerIds) {
      return request.auth.uid in partnerIds;
    }

    function isAllowedPair() {
      return request.auth.token.email == 'dhruvya@blablu.app' || request.auth.token.email == 'anjali@blablu.app';
    }

    match /users/{userId} {
      allow write: if isAuthenticated() && isAllowedPair() && request.auth.uid == userId;
      allow read: if isAuthenticated() && isAllowedPair();
    }

    match /pairs/{roomId} {
      allow read, write: if isAuthenticated() && isAllowedPair() && roomId == 'blablu_nest';
      
      match /{document=**} {
        allow read, write: if isAuthenticated() && isAllowedPair() && roomId == 'blablu_nest';
      }
    }
    
    match /{document=**} {
      allow read, write: if false; // Deny by default
    }
  }
}
